# Application Settings
APP_NAME="Ovi Pregnancy Nutrition API"
DEBUG=True
VERSION="0.1.0"
API_PREFIX="/api"

# Security
SECRET_KEY="your-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ovi"

# Supabase
SUPABASE_URL="your-supabase-url"
SUPABASE_KEY="your-supabase-key"  # anon public key
# JWT verification for Supabase Auth tokens (social login / OAuth).
# Primary path: HS256 shared secret. Get it from Supabase Dashboard →
# Settings → API → JWT Settings → JWT Secret. Required if your project's
# current key is "Legacy HS256 (Shared Secret)".
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
# Optional: override JWKS / issuer (defaults derived from SUPABASE_URL).
# SUPABASE_JWKS_URL="https://YOUR_PROJECT_REF.supabase.co/auth/v1/keys"
# SUPABASE_JWT_ISSUER="https://YOUR_PROJECT_REF.supabase.co/auth/v1"
SUPABASE_JWT_AUDIENCE="authenticated"

# Legacy email/password login (set false to disable /auth/register, /auth/login, /auth/refresh)
# LEGACY_AUTH_ENABLED=true

# External APIs
USDA_API_KEY="your-usda-api-key"
SPOONACULAR_API_KEY="your-spoonacular-api-key"
GEMINI_API_KEY="your-gemini-api-key"  # Get from https://ai.google.dev/

# Email Settings (for password reset)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-email-password"
EMAIL_FROM="your-email@gmail.com"
EMAIL_RESET_TOKEN_EXPIRE_HOURS=24

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:3000,http://localhost:19006,exp://*"
